# ======================================================
# BAM Financeiro — Variáveis de Ambiente do Backend
# ======================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o .env com valores reais no repositório.

# Código de acesso para o login (defina algo forte para produção)
ACCESS_CODE=mude-este-codigo-aqui

# Chave secreta para assinar os tokens de sessão
# Gere em produção com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-aqui

# Ambiente: "development" (padrão) ou "production"
# Em produção: cookie recebe Secure=True e SameSite=None (necessário para cross-origin)
ENVIRONMENT=development

# URL do frontend — necessária em produção para o CORS
# Exemplo: https://bam-financeiro.vercel.app
FRONTEND_URL=

# Horas de expiração da sessão (padrão: 24)
TOKEN_EXPIRE_HOURS=24

# Bypass temporário da autenticação local (use false em produção)
AUTH_BYPASS=false
