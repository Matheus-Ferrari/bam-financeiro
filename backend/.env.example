# ─────────────────────────────────────────────────────────────────
# BAM Financeiro — variáveis de ambiente do backend
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais no repositório.
# ─────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────
# Opção 1 (recomendada): Secret Manager
# Nome do secret no Google Cloud Secret Manager que contém o JSON
# completo da Service Account. Crie em: GCP Console → Secret Manager
FIREBASE_SECRET_NAME=firebase-service-account
FIREBASE_SECRET_VERSION=latest

# Opção 2 (fallback local/dev): arquivo JSON na máquina
# Descomente se NÃO usar Secret Manager.
# FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# ID do projeto Google Cloud (obrigatório em ambas as opções)
FIREBASE_PROJECT_ID=seu-projeto-firebase

# ID da empresa/tenant padrão usado por todos os requests via cookie.
# Deve corresponder a um documento em Firestore: companies/{FIREBASE_COMPANY_ID}
FIREBASE_COMPANY_ID=bam

# ── Autenticação / Sessão (cookie legado) ─────────────────────────
# Código de acesso da tela de login do frontend.
# Deixe vazio para desabilitar o login por código.
ACCESS_CODE=mude-este-codigo-aqui

# Chave secreta HMAC para geração dos cookies de sessão.
# Em produção: gere com python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-aqui

# Duração da sessão cookie em horas (padrão: 24)
TOKEN_EXPIRE_HOURS=24

# ── Bypass de autenticação (apenas desenvolvimento) ───────────────
# Se true, todos os endpoints ficam acessíveis sem token/cookie.
# NUNCA use true em produção.
AUTH_BYPASS=false

# ── Servidor ──────────────────────────────────────────────────────
# Ambiente: "development" (padrão) ou "production"
# Em produção: cookie recebe Secure=True e SameSite=None
ENVIRONMENT=development

# URL do frontend (adicionada ao CORS em produção).
# Exemplo: https://bam-financeiro.vercel.app
FRONTEND_URL=
